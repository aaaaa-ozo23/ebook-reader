{
  "name": "ebook-reader",
  "version": "0.2.0",
  "license": "MIT",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.1.2",
  "engines": {
    "node": ">=26.1.0",
    "pnpm": ">=11.1.2"
  },
  "scripts": {
    "build": "pnpm -r build",
    "check": "pnpm run lint && pnpm run format && pnpm run build && pnpm run test",
    "format": "prettier --check .",
    "format:write": "prettier --write .",
    "lint": "eslint .",
    "test": "pnpm -r --if-present test",
    "deps:libmobi": "powershell -ExecutionPolicy Bypass -File scripts/deps/build-libmobi.ps1",
    "deps:verify-libmobi": "node scripts/deps/verify-libmobi.mjs",
    "tauri:build:nsis": "node scripts/build-windows-flavor.mjs nsis",
    "tauri:build:msi": "node scripts/build-windows-flavor.mjs msi",
    "release:audit": "node scripts/release/audit-licenses.mjs",
    "release:security": "node scripts/release/verify-release-security.mjs",
    "release:rc": "powershell -ExecutionPolicy Bypass -File scripts/release/build-release.ps1",
    "verify:release": "node scripts/verify-release.mjs"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.5.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "globals": "^17.6.0",
    "prettier": "^3.8.4",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.1"
  }
}
